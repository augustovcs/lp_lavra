---
const nav = [
  { title: 'Navegar', links: [
    { href: '#servicos', label: 'Serviços' },
    { href: '#processo', label: 'Processo' },
    { href: '#cases', label: 'Cases' },
    { href: '#sobre', label: 'Sobre' },
  ] },
  { title: 'Serviços', links: [
    { href: '#servicos', label: 'Sistemas web' },
    { href: '#servicos', label: 'Automações' },
    { href: '#servicos', label: 'Landing pages' },
  ] },
];
const year = new Date().getFullYear();
---
<footer class="f2">
  <div class="wrap">
    <div class="row">
      <div class="left">
        <p class="tagline"><em>Sempre o próximo passo.</em></p>
        <div class="contact">
          <a href="mailto:contato@noven.dev">contato@noven.dev</a>
          <a href="#contato" class="ph">[WhatsApp: (00) 00000-0000]</a>
        </div>
      </div>
      <nav class="nav" aria-label="Rodapé">
        {nav.map((g) => (
          <div class="grp">
            <h2>{g.title}</h2>
            {g.links.map((l) => <a href={l.href}>{l.label}</a>)}
          </div>
        ))}
      </nav>
    </div>

    <div class="wordmark" aria-hidden="true">Noven<span class="dot">.</span></div>

    <div class="legal">
      <span>© {year} Noven · do conceito à escala</span>
      <div class="social">
        <a href="#" rel="noopener">Instagram</a>
        <a href="#" rel="noopener">LinkedIn</a>
        <a href="#" rel="noopener">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .f2 { padding-top: 56px; padding-bottom: 40px; border-top: 1px solid var(--line); }
  .row { display: flex; justify-content: space-between; gap: 30px; flex-wrap: wrap; margin-bottom: 44px; }
  .tagline { font-family: var(--serif); font-size: 1.3rem; color: var(--ink); max-width: 24ch; line-height: 1.35; }
  .contact { margin-top: 18px; display: grid; gap: 6px; }
  .contact a { font-size: .96rem; color: var(--muted); transition: color .2s; }
  .contact a:hover { color: var(--accent); }
  .ph { opacity: .85; font-style: italic; }
  .nav { display: flex; gap: 48px; flex-wrap: wrap; }
  .grp h2 { font-size: .74rem; letter-spacing: .1em; text-transform: uppercase; color: var(--soft); margin-bottom: 14px; font-weight: 600; }
  .nav a { display: block; margin-bottom: 9px; font-size: .94rem; color: var(--muted); transition: color .2s; }
  .nav a:hover { color: var(--accent); }
  .wordmark {
    font-weight: 900; font-size: clamp(3.5rem, 16vw, 11rem); letter-spacing: -.05em;
    line-height: .8; color: var(--ink); border-top: 1px solid var(--line); padding-top: 24px;
  }
  .wordmark .dot { color: var(--accent); }
  .legal { display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-top: 22px; font-size: .82rem; color: var(--soft); }
  .legal .social { display: flex; gap: 16px; }
  .legal .social a { transition: color .2s; }
  .legal .social a:hover { color: var(--accent); }

  @media (max-width: 820px) {
    .row { flex-direction: column; gap: 30px; }
  }
</style>
