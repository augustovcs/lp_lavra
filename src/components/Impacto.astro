---
const stats = [
  { n: 80, suffix: '+', label: 'projetos no ar' },
  { n: 12, suffix: 'h', label: 'economizadas/semana' },
  { n: 8, suffix: ' sem', label: 'do conceito ao ar' },
  { n: 100, suffix: '%', label: 'times sêniores' },
];
---
<section class="impacto" aria-label="Números da Noven">
  <div class="wrap">
    <div class="bgrid">
      {stats.map((s) => (
        <div class="it">
          <span class="big" data-count={s.n} data-suffix={s.suffix}>{s.n}{s.suffix}</span>
          <span class="lbl">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .impacto { padding: 36px 0; border-bottom: 1px solid var(--line); }
  .bgrid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--line); border-radius: 16px; overflow: hidden;
  }
  .it { padding: 30px 24px; border-right: 1px solid var(--line); }
  .it:last-child { border-right: none; }
  .big { font-weight: 800; letter-spacing: -.03em; line-height: 1; font-size: 2.4rem; display: block; }
  .lbl { color: var(--muted); font-size: .9rem; display: block; margin-top: 8px; }

  @media (max-width: 820px) {
    .bgrid { grid-template-columns: 1fr 1fr; }
    .it:nth-child(2) { border-right: none; }
    .it:nth-child(1), .it:nth-child(2) { border-bottom: 1px solid var(--line); }
  }
  @media (max-width: 520px) {
    .bgrid { grid-template-columns: 1fr; }
    .it { border-right: none; border-bottom: 1px solid var(--line); }
    .it:last-child { border-bottom: none; }
  }
</style>
