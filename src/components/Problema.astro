---
const bad = [
  'Ideia parada na sua cabeça',
  'Planilha que trava e ninguém mantém',
  'Orçamento caro, lento e confuso',
  'Você perdido no meio do processo',
];
const good = [
  'Ideia no ar, do conceito à escala',
  'Sistema sob medida pro seu fluxo',
  'Caminho claro, sem jargão',
  'Você só acompanha funcionando',
];
---
<section class="sec problema" id="problema">
  <div class="wrap">
    <div class="sec-head">
      <span class="kicker">Soa familiar?</span>
      <h2>A ideia é sua. <em>Falta quem execute.</em></h2>
      <p>O problema e a solução, lado a lado — para você ver o contraste por inteiro.</p>
    </div>

    <div class="pasrow">
      <div class="half p">
        <p class="k">O problema</p>
        <p class="ph"><span class="dim">Você tem a ideia.</span> Falta quem execute.</p>
      </div>
      <div class="half s">
        <p class="k">A solução</p>
        <p class="ph">Você pensa, <span class="hl">a gente faz acontecer.</span></p>
      </div>
    </div>

    <div class="ba">
      <div class="col bad">
        <div class="ch"><span class="ico" aria-hidden="true">✕</span> Como costuma ser</div>
        <ul>{bad.map((t) => <li>{t}</li>)}</ul>
      </div>
      <div class="col good">
        <div class="ch"><span class="ico" aria-hidden="true">✓</span> Com a Noven</div>
        <ul>{good.map((t) => <li>{t}</li>)}</ul>
      </div>
    </div>
  </div>
</section>

<style>
  .pasrow { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 16px; }
  .half { padding: 0 4px; }
  .half .k { font-size: .76rem; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; }
  .half.p .k { color: var(--bad); }
  .half.s .k { color: var(--accent); }
  .half .ph { font-weight: 700; font-size: clamp(1.4rem, 2.8vw, 2rem); letter-spacing: -.02em; line-height: 1.2; }
  .half.p .ph .dim { color: var(--soft); }
  .half.s .ph .hl { color: var(--accent); }

  .ba { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .col { border: 1px solid var(--line); border-radius: 16px; padding: 26px; background: var(--surface); }
  .col.good { background: var(--feat); border-color: transparent; }
  .ch { display: flex; align-items: center; gap: 10px; font-weight: 500; margin-bottom: 16px; font-size: .95rem; }
  .col.bad .ch { color: var(--bad); }
  .col.good .ch { color: var(--feat-accent); }
  .ico { width: 26px; height: 26px; border-radius: 50%; display: grid; place-items: center; font-size: .8rem; flex: none; }
  .bad .ico { background: color-mix(in srgb, var(--bad) 16%, transparent); color: var(--bad); }
  .good .ico { background: color-mix(in srgb, var(--feat-accent) 22%, transparent); color: var(--feat-accent); }
  ul { list-style: none; display: grid; gap: 11px; }
  li { display: flex; gap: 10px; font-size: .95rem; align-items: flex-start; }
  .bad li { color: var(--muted); }
  .good li { color: var(--feat-soft); }
  .bad li::before { content: "✕"; color: var(--bad); font-size: .8rem; margin-top: 2px; }
  .good li::before { content: "→"; color: var(--feat-accent); margin-top: 1px; }

  @media (max-width: 820px) {
    .pasrow, .ba { grid-template-columns: 1fr; }
    .half.s { margin-top: 6px; }
  }
</style>
