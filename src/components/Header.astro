---
const links = [
  { href: '#servicos', label: 'Serviços' },
  { href: '#processo', label: 'Processo' },
  { href: '#cases', label: 'Cases' },
  { href: '#sobre', label: 'Sobre' },
];
---

<header class="top">
  <div class="wrap top-in">
    <a class="logo" href="#topo" aria-label="Noven — início">
      <svg class="mark" viewBox="0 0 32 32" width="27" height="27" fill="none" aria-hidden="true" focusable="false">
        <circle cx="16" cy="23" r="4" fill="var(--accent)" />
        <path d="M16 22 V7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
        <path d="M9.5 13 L16 6.5 L22.5 13" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="word">Noven<span class="dot">.</span></span>
    </a>
    <nav class="links" aria-label="Navegação principal">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <button class="mode" type="button" aria-pressed="false" aria-label="Alternar tema claro e escuro">
      <svg class="ic ic-light" viewBox="0 0 24 24" width="17" height="17" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8" />
        <path d="M12 2.5V5M12 19v2.5M2.5 12H5M19 12h2.5M5.1 5.1l1.8 1.8M17.1 17.1l1.8 1.8M18.9 5.1l-1.8 1.8M6.9 17.1l-1.8 1.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
      <svg class="ic ic-dark" viewBox="0 0 24 24" width="17" height="17" fill="none" aria-hidden="true">
        <path d="M20 14.5A8 8 0 1 1 9.5 4a6.3 6.3 0 0 0 10.5 10.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
      </svg>
    </button>
    <a class="btn btn-solid btn-sm cta" href="#contato">Vamos conversar</a>
  </div>
</header>

<style>
  .top {
    position: sticky; top: 0; z-index: 100;
    transform: translateY(0); transition: transform .35s var(--ease), background .5s var(--ease);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(8px);
    border-bottom: 1px solid var(--line);
    transition: background .5s var(--ease);
  }
  .top-in { display: flex; align-items: center; gap: 22px; height: 66px; }

  /* Lockup: símbolo + wordmark */
  .logo { display: inline-flex; align-items: center; gap: 9px; }
  .logo .mark { flex: none; color: var(--ink); transition: transform .35s var(--ease); }
  .logo:hover .mark { transform: translateY(-2px); }
  .logo .word { line-height: 1; }

  .links { display: flex; gap: 22px; margin-left: 8px; }
  .links a { font-size: .9rem; color: var(--soft); transition: color .2s; }
  .links a:hover { color: var(--ink); }

  .mode {
    margin-left: auto; display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; padding: 0; cursor: pointer; color: var(--soft);
    background: transparent; border: 1px solid var(--line); border-radius: 100px;
    transition: color .2s, border-color .2s, background .3s;
  }
  .mode:hover { color: var(--ink); border-color: var(--soft); }
  .mode:active { transform: scale(.95); }
  .mode .ic-dark { display: none; }
  html[data-theme="floresta"] .mode .ic-light { display: none; }
  html[data-theme="floresta"] .mode .ic-dark { display: inline; }

  @media (max-width: 900px) {
    .links { display: none; }
  }
  @media (max-width: 600px) {
    .cta { display: none; }
  }
</style>

<script>
  import '../scripts/theme.js';

  // Header: esconde ao rolar pra baixo, reaparece ao rolar pra cima
  const header = document.querySelector('.top');
  if (header) {
    let lastY = 0;
    let hidden = false;
    const THRESHOLD = 200;

    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y > THRESHOLD && y > lastY && !hidden) {
        header.style.transform = 'translateY(-100%)';
        hidden = true;
      } else if (y < lastY && hidden) {
        header.style.transform = 'translateY(0)';
        hidden = false;
      }
      lastY = y;
    }, { passive: true });
  }
</script>
