---
// Cases — formato revista: case-herói com comparador antes/depois interativo,
// faixa de impacto e uma grade de cases secundários.
const bandStats = [
  { n: 8, suffix: ' sem', label: 'do papel ao app no ar', count: true },
  { v: '−90%', label: 'erros de estoque' },
  { v: '12h→20min', label: 'fechamento financeiro' },
];
const grid = [
  { brand: 'Veloz Log', result: 'App de rotas no ar em 8 semanas', quote: 'Botaram nosso app no ar num prazo que eu não acreditei.', av: 'RD' },
  { brand: 'Studio Lima', result: 'Landing que dobrou os contatos', quote: 'Rápidos, claros e sem enrolação.', av: 'CL' },
  { brand: 'GG Contábil', result: 'Fechamento manual automatizado', quote: 'Sumiu o retrabalho. Recomendo de olhos fechados.', av: 'TG' },
];
---
<section class="sec cases" id="cases">
  <div class="wrap">
    <div class="sec-head">
      <span class="kicker">Cases de sucesso</span>
      <h2>Histórias que <em>saíram do papel</em>.</h2>
      <p>Arraste o divisor no case em destaque para ver o antes e o depois.</p>
    </div>

    <!-- CASE-HERÓI (magazine) -->
    <article class="hero-case">
      <div class="ba-stage">
        <div class="ba-slider" data-ba-slider>
          <!-- ANTES: planilha travada -->
          <div class="ba-pane before" aria-hidden="true">
            <div class="screen">
              <div class="screen-bar"><i></i><i></i><i></i><span class="fname">controle.xlsx</span></div>
              <div class="sheet">
                {Array.from({ length: 7 }).map(() => (
                  <div class="srow">
                    <span class="cell w3"></span><span class="cell w5"></span>
                    <span class="cell w3"></span><span class="cell w8 warn"></span>
                  </div>
                ))}
              </div>
            </div>
            <span class="ba-tag bad">Antes</span>
          </div>

          <!-- DEPOIS: sistema sob medida -->
          <div class="ba-pane after" data-ba-after>
            <div class="screen">
              <div class="screen-bar"><i></i><i></i><i></i><span class="fname">painel.lavra.app</span></div>
              <div class="dash">
                <div class="cards">
                  <span class="cc on"></span><span class="cc"></span><span class="cc"></span>
                </div>
                <span class="bar w8"></span><span class="bar w7"></span>
                <span class="bar w5"></span><span class="bar w8"></span>
              </div>
            </div>
            <span class="ba-tag good">Depois</span>
          </div>

          <div
            class="ba-handle"
            data-ba-handle
            role="slider"
            tabindex="0"
            aria-label="Comparar antes e depois"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="50"
          >
            <span class="knob" aria-hidden="true">⟺</span>
          </div>
        </div>
      </div>

      <div class="story">
        <span class="brand">Clínica Norte</span>
        <h3>Da planilha que travava a um sistema que a equipe ama.</h3>
        <p class="excerpt">
          A Clínica Norte arrastava agendamentos e estoque numa planilha que ninguém
          mantinha. A gente desenhou e construiu um sistema sob medida — e devolveu
          12 horas por semana pro time.
        </p>
        <blockquote>
          “Eu só precisei ter a ideia. A Lavra entendeu tudo e colocou no ar.”
          <cite><span class="av">MR</span> Marina Rocha · Fundadora</cite>
        </blockquote>
      </div>
    </article>

    <!-- FAIXA DE IMPACTO -->
    <div class="band" aria-label="Resultados">
      {bandStats.map((s) => (
        <div class="bstat">
          {s.count ? (
            <span class="bbig" data-count={s.n} data-suffix={s.suffix}>{s.n}{s.suffix}</span>
          ) : (
            <span class="bbig">{s.v}</span>
          )}
          <span class="blbl">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- GRADE DE CASES -->
    <div class="grid">
      {grid.map((c) => (
        <article class="gcard">
          <span class="brand">{c.brand}</span>
          <h4>{c.result}</h4>
          <p class="gquote">“{c.quote}”</p>
          <span class="gauthor"><span class="av sm">{c.av}</span></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* CASE-HERÓI */
  .hero-case {
    display: grid; grid-template-columns: 1.05fr 1fr; gap: 36px; align-items: center;
    background: var(--surface); border: 1px solid var(--line); border-radius: 22px;
    padding: 22px; margin-bottom: 18px;
  }

  /* Comparador antes/depois */
  .ba-stage { border-radius: 14px; overflow: hidden; }
  .ba-slider {
    position: relative; aspect-ratio: 4 / 3; border-radius: 14px; overflow: hidden;
    border: 1px solid var(--line); touch-action: none; cursor: ew-resize; user-select: none;
  }
  .ba-pane { position: absolute; inset: 0; }
  .ba-pane.after { clip-path: inset(0 0 0 50%); }
  .ba-tag {
    position: absolute; bottom: 12px; font-size: .72rem; font-weight: 600;
    letter-spacing: .04em; text-transform: uppercase; padding: 4px 11px; border-radius: 100px;
  }
  .ba-tag.bad { left: 12px; background: color-mix(in srgb, var(--bad) 18%, var(--surface)); color: var(--bad); }
  .ba-tag.good { right: 12px; background: var(--accent); color: var(--accent-ink); }

  .screen { position: absolute; inset: 0; background: var(--bg); display: flex; flex-direction: column; }
  .screen-bar { height: 30px; display: flex; align-items: center; gap: 5px; padding: 0 12px; border-bottom: 1px solid var(--line); }
  .screen-bar i { width: 8px; height: 8px; border-radius: 50%; background: var(--line); }
  .fname { margin-left: 10px; font-size: .74rem; color: var(--soft); font-family: var(--mono); }

  .sheet { flex: 1; padding: 14px; display: flex; flex-direction: column; gap: 9px; }
  .srow { display: flex; gap: 8px; }
  .cell { height: 11px; border-radius: 3px; background: var(--ink); opacity: .12; }
  .cell.warn { background: var(--bad); opacity: .3; }

  .dash { flex: 1; padding: 16px; display: flex; flex-direction: column; gap: 11px; }
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .cc { height: 46px; border-radius: 8px; background: var(--ink); opacity: .07; }
  .cc.on { background: var(--accent); opacity: 1; }
  .bar { height: 8px; border-radius: 4px; background: var(--ink); opacity: .12; }

  .ba-handle {
    position: absolute; top: 0; bottom: 0; left: 50%; width: 3px; margin-left: -1.5px;
    background: var(--accent); cursor: ew-resize;
  }
  .knob {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 38px; height: 38px; border-radius: 50%; background: var(--accent); color: var(--accent-ink);
    display: grid; place-items: center; font-size: .9rem; box-shadow: 0 4px 14px -4px rgba(0, 0, 0, .5);
  }

  .story .brand,
  .gcard .brand {
    font-family: var(--serif); font-style: italic; font-weight: 700;
    color: var(--accent); font-size: 1rem;
  }
  .story h3 { font-weight: 700; font-size: 1.6rem; letter-spacing: -.02em; line-height: 1.18; margin: 10px 0 14px; }
  .excerpt { color: var(--muted); font-size: 1rem; margin-bottom: 20px; }
  blockquote { border-left: 2px solid var(--accent); padding-left: 16px; font-family: var(--serif); font-size: 1.08rem; line-height: 1.4; color: var(--ink); }
  cite { display: flex; align-items: center; gap: 10px; margin-top: 12px; font-style: normal; font-family: var(--sans); font-size: .86rem; color: var(--soft); }
  .av { width: 34px; height: 34px; border-radius: 50%; background: var(--accent); color: var(--accent-ink); display: grid; place-items: center; font-weight: 700; font-size: .82rem; flex: none; }
  .av.sm { width: 30px; height: 30px; font-size: .76rem; }

  /* FAIXA DE IMPACTO */
  .band {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    background: var(--feat); border-radius: 18px; padding: 32px 36px; margin-bottom: 18px;
  }
  .bstat { display: flex; flex-direction: column; gap: 6px; }
  .bbig { font-weight: 800; font-size: clamp(1.6rem, 3vw, 2.3rem); letter-spacing: -.03em; color: var(--feat-accent); line-height: 1; }
  .blbl { color: var(--feat-soft); font-size: .9rem; }

  /* GRADE DE CASES */
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .gcard {
    background: var(--surface); border: 1px solid var(--line); border-radius: 16px;
    padding: 24px 22px; display: flex; flex-direction: column; gap: 10px;
    transition: border-color .25s var(--ease), transform .25s var(--ease);
  }
  .gcard:hover { border-color: var(--accent); transform: translateY(-4px); }
  .gcard h4 { font-weight: 700; font-size: 1.1rem; letter-spacing: -.015em; line-height: 1.25; }
  .gquote { font-family: var(--serif); color: var(--muted); font-size: .98rem; flex: 1; }
  .gauthor { margin-top: 4px; }

  @media (max-width: 820px) {
    .hero-case { grid-template-columns: 1fr; gap: 24px; }
    .band { grid-template-columns: 1fr; gap: 18px; text-align: left; }
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import '../scripts/cases.js';
</script>
