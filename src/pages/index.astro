---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Impacto from '../components/Impacto.astro';
import Problema from '../components/Problema.astro';
import Servicos from '../components/Servicos.astro';
import Globo from '../components/Globo.astro';
import Processo from '../components/Processo.astro';
import Cases from '../components/Cases.astro';
import Depoimentos from '../components/Depoimentos.astro';
import Formulario from '../components/Formulario.astro';
import Sobre from '../components/Sobre.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main id="conteudo">
    <Hero />
    <Impacto />
    <Problema />
    <Servicos />
    <Globo />
    <Processo />
    <Cases />
    <Depoimentos />
    <Formulario />
    <Sobre />
    <CtaFinal />
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/counters.js';
  import '../scripts/reveal.js';
</script>
