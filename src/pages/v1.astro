    .stats { grid-template-columns: 1fr 1fr; } }

  /* reveal — só esconde com JS (.js no <html>); sem JS, conteúdo visível p/ SEO/no-JS */
  :global(.js) [data-reveal] { opacity: 0; transform: translateY(20px); transition: opacity .7s var(--ease), transform .7s var(--ease); }
  [data-reveal].in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce){ [data-reveal]{ opacity:1; transform:none; } .float-card{ animation:none; } }
</style>

<script>
  import '../scripts/reveal-generic.js';
  import '../scripts/globe.js';
  // count-up dos stats
  const nums = document.querySelectorAll('.v1 .num');
  const io = new IntersectionObserver((es) => es.forEach((e) => {
    if (!e.isIntersecting) return;
    const el = e.target; const to = +el.dataset.to; let n = 0;
    const t = setInterval(() => { n += Math.ceil(to / 28); if (n >= to) { n = to; clearInterval(t); } el.textContent = String(n); }, 28);
    io.unobserve(el);
  }), { threshold: .6 });
  nums.forEach((n) => io.observe(n));
</script>
